generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  admin
  user
}

enum QuizStatus {
  draft
  submitted
  approved
  rejected
}

enum ArenaMatchStatus {
  waiting
  countdown
  playing
  finished
}

model User {
  id                     String   @id @default(uuid())
  email                  String   @unique
  password_hash          String
  display_name           String?
  avatar_url             String?
  name_changes_remaining Int      @default(2)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  quizzes       quizzes[]
  quiz_attempts quiz_attempts[]
  user_roles    user_roles[]
  arena_ratings arena_ratings?
  arena_participants arena_participants[]
}

model user_roles {
  id      String  @id @default(uuid())
  user_id String
  role    AppRole

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role])
}

model quizzes {
  id                 String     @id @default(uuid())
  creator_id         String
  title              String
  description        String?
  category           String
  difficulty         String     @default("medium")
  time_limit_seconds Int?       @default(30)
  status             QuizStatus @default(draft)
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt
  slug               String     @unique

  creator        User             @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  quiz_questions quiz_questions[]
  quiz_attempts  quiz_attempts[]
  arena_matches  arena_matches[]
}

model quiz_questions {
  id             String   @id @default(uuid())
  quiz_id        String
  question_text  String
  options        Json
  correct_answer Json
  explanation    String?
  order_index    Int      @default(0)
  created_at     DateTime @default(now())
  question_type  String   @default("single_mcq")

  quiz quizzes @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
}

model quiz_attempts {
  id              String    @id @default(uuid())
  user_id         String
  quiz_id         String
  score           Int       @default(0)
  total_questions Int
  answers         Json?
  completed_at    DateTime?
  created_at      DateTime  @default(now())

  user User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  quiz quizzes @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
}

model arena_matches {
  id                     String           @id @default(uuid())
  quiz_id                String
  host_id                String
  room_code              String           @unique
  status                 ArenaMatchStatus @default(waiting)
  max_players            Int              @default(10)
  current_question_index Int              @default(0)
  question_started_at    DateTime?
  created_at             DateTime         @default(now())
  started_at             DateTime?
  finished_at            DateTime?
  is_official            Boolean          @default(false)
  scheduled_start_at     DateTime?
  min_rating             Int?
  max_rating             Int?
  allow_unrated          Boolean          @default(true)
  join_cutoff_ratio      Float            @default(0.75)

  quiz               quizzes              @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  arena_participants arena_participants[]
}

model arena_participants {
  id                     String    @id @default(uuid())
  match_id               String
  user_id                String
  score                  Int       @default(0)
  total_time_ms          Int       @default(0)
  answers                Json?     @default("[]")
  is_ready               Boolean   @default(false)
  joined_at              DateTime  @default(now())
  finished_at            DateTime?
  question_started_at    DateTime?
  current_question_index Int       @default(0)
  player_phase           String    @default("answering")

  match arena_matches @relation(fields: [match_id], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([match_id, user_id])
}

model arena_ratings {
  id             String   @id @default(uuid())
  user_id        String   @unique
  rating         Float    @default(1500)
  deviation      Float    @default(350)
  volatility     Float    @default(0.06)
  matches_played Int      @default(0)
  wins           Int      @default(0)
  total_score    Int      @default(0)
  updated_at     DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}